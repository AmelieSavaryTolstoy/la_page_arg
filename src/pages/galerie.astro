---
import "./styles/global.css";
import { sortedArticles, categories } from "./data/articles";

const now = new Date();
const formattedDate = now.toLocaleDateString('fr-FR', {
	weekday: 'long',
	day: 'numeric',
	month: 'long'
});
const dateLabel = formattedDate.charAt(0).toUpperCase() + formattedDate.slice(1);
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Aoboshi+One&family=Annapurna+SIL:wght@400;700&display=swap" rel="stylesheet"/>
		<link rel="stylesheet" href="../pages/styles/global.css" />
        <title>La Page — Galerie</title>
    </head>
    <body>
        <header>
            <a href="/" style="text-decoration:none;">
                <h1 class="logo">LA P<span>A</span>GE</h1>
            </a>
			<p class="date">{dateLabel}</p>
            <div class="yellow-bar"></div>
            <nav class="arianne">
                <a href="/">Accueil</a>
                <span class="arrianne-sep">/</span>
                <a href="/galerie">Tous les articles</a>
            </nav>
        </header>

        <div class="galerie-page">
            <h2 class="title">Nos articles</h2>
            <nav class="tags">
                {
                    categories.map((cat) => (
                        <button
                            class={`tag${cat === "Tous" ? " active" : ""}`}
                            data-category={cat}
                        >
                            {cat}
                        </button>
                    ))
                }
            </nav>

            <div class="gallery-grid" id="gallery-grid">
                {
                    sortedArticles.map((article) => (
                        <div
                            class="gallery-card"
                            data-category={article.category}
                        >
                            <div class="article-hero-img">
                                {article.image
                                    ? <img src={article.image} alt={article.alt} />
                                    : <div class="img-placeholder" style="width:100%; height:100%;" />
                                }
                            </div>
                            <div class="gallery-card-body">
                                <div class="gallery-card-meta">
                                    <span class="tag-badge">
                                        {article.category}
                                    </span>
                                    <span class="featured-date">
                                        {article.date}
                                    </span>
                                </div>
                                <a href={`/article/${article.id}`} class="card-title link-title">
                                    <h3>{article.title}</h3>
                                </a>
                                <p class="gallery-card-excerpt">
                                    {article.excerpt}
                                </p>
                                <div style="display:flex; justify-content:flex-end;">
                                    <a href={`/article/${article.id}`} class="btn-discover" title="Lire l'article complet">En découvrir plus →</a>
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <footer>
			<p class="footer-logo">LA P<span>A</span>GE</p>
			<div class="footer-links">
				<a href="/cgvcgu">Politique de confidentialité</a>
			</div>
		</footer>
        <script>
            const tags = document.querySelectorAll<HTMLButtonElement>(".tag");
            const cards =
                document.querySelectorAll<HTMLElement>(".gallery-card");

            tags.forEach((btn) => {
                btn.addEventListener("click", () => {
                    tags.forEach((b) => b.classList.remove("active"));
                    btn.classList.add("active");

                    const selected = btn.dataset.category;

                    cards.forEach((card) => {
                        const show =
                            selected === "Tous" ||
                            card.dataset.category === selected;
                        card.style.display = show ? "flex" : "none";
                    });
                });
            });
        </script>
    </body>
</html>
